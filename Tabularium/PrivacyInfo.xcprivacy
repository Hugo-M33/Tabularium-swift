<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- NSPrivacyTracking=false au niveau du manifest : Apple n'autorise pas
	     NSPrivacyTracking=true sans au moins un domaine dans
	     NSPrivacyTrackingDomains (sinon ITMS-91064), et Google ne publie pas de
	     liste de domaines de tracking pour le SDK Mobile Ads. On NE déclare donc
	     PAS la clé NSPrivacyTrackingDomains (même vide, sa présence peut suffire
	     à déclencher le validateur). L'usage réel de l'IDFA pour la pub se
	     déclare dans le questionnaire « App Privacy » d'App Store Connect. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<!-- Aucune collecte de données par l'app elle-même (pas de backend ;
	     CloudKit dormant). La collecte du SDK pub est déclarée dans SON manifest. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs réellement utilisées par l'app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
