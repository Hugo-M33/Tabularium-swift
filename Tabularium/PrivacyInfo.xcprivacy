<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- L'app elle-même n'effectue aucun tracking : c'est le SDK Google Mobile
	     Ads qui contacte les domaines de tracking et les déclare dans SON
	     manifest embarqué (NSPrivacyTracking=true + domaines). Apple fusionne
	     tous les manifests à la soumission. Si NSPrivacyTracking est true ici,
	     NSPrivacyTrackingDomains doit être non vide (sinon ITMS-91064). -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Aucune collecte de données par l'app elle-même (pas de backend ;
	     CloudKit dormant). La collecte du SDK pub est déclarée dans SON manifest. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs réellement utilisées par l'app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
