<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- L'app utilise l'IDFA via Google Mobile Ads pour des pubs personnalisées
	     (prompt ATT au lancement). -->
	<key>NSPrivacyTracking</key>
	<true/>
	<!-- Domaines de tracking : fournis par le manifest embarqué du SDK
	     Google Mobile Ads ; rien à déclarer au niveau de l'app. -->
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- Aucune collecte de données par l'app elle-même (pas de backend ;
	     CloudKit dormant). La collecte du SDK pub est déclarée dans SON manifest. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs réellement utilisées par l'app. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
